# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
# Para PostgreSQL em produção, descomente e configure:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=rotasegura_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001,http://127.0.0.1

# JWT Configuration (em dias)
JWT_ACCESS_TOKEN_LIFETIME=7
JWT_REFRESH_TOKEN_LIFETIME=30

# Internationalization
LANGUAGE_CODE=pt-br
TIME_ZONE=America/Sao_Paulo

# API Configuration
API_BASE_URL=http://localhost:8000/api

# Rate Limiting Configuration (Throttle)
# Formato: requests/time_unit (min=minuto, s=segundo, h=hora)
THROTTLE_ANON=10/min              # Usuários anônimos geral: 10/min
THROTTLE_USER=100/min             # Usuários autenticados geral: 100/min
THROTTLE_AUTH=3/min               # Endpoints de auth: 3/min
THROTTLE_LIST_ANON=20/min         # GET listagem anônimo: 20/min
THROTTLE_LIST_AUTH=200/min        # GET listagem autenticado: 200/min
THROTTLE_CREATE_ANON=5/min        # POST criação anônimo: 5/min
THROTTLE_CREATE_AUTH=50/min       # POST criação autenticado: 50/min
